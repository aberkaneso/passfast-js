{
  "name": "@passfast/sdk",
  "version": "2.2.0",
  "description": "Official TypeScript SDK for the PassFast Apple Wallet Pass platform",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "apple-wallet",
    "passkit",
    "pkpass",
    "wallet-pass",
    "passfast"
  ],
  "author": "PassFast",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aberkaneso/passfast-js"
  },
  "homepage": "https://passfa.st",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
